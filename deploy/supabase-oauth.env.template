# Fragmento para o .env do Supabase Docker (Hetzner)
# Ficheiro no servidor: /caminho/para/supabase/docker/.env
# Após editar: docker compose down && docker compose up -d

############
# URLs
############
SUPABASE_PUBLIC_URL=https://supabase.visualdesignmoz.com
API_EXTERNAL_URL=https://supabase.visualdesignmoz.com
SITE_URL=https://visualdesignmoz.com

# Redirect URLs permitidas após OAuth / confirmação de email
ADDITIONAL_REDIRECT_URLS=https://visualdesignmoz.com/auth/callback,https://visualdesignmoz.com/auth/callback**,https://visualdesignmoz.com/auth/confirm,https://visualdesignmoz.com/auth/reset-password,https://www.visualdesignmoz.com/auth/callback,https://painel.visualdesignmoz.com/auth/callback,http://localhost:3002/auth/callback,http://localhost:3002/auth/callback**,http://localhost:3002/auth/confirm

# No Google Cloud Console → Credentials → OAuth 2.0:
#   Authorized redirect URIs:
#     https://supabase.visualdesignmoz.com/auth/v1/callback
#   Authorized JavaScript origins:
#     https://visualdesignmoz.com
#     https://www.visualdesignmoz.com
#     https://supabase.visualdesignmoz.com
#     http://localhost:3002

############
# Google OAuth (login com Google na app)
############
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=<seu-client-id>.apps.googleusercontent.com
GOOGLE_SECRET=<seu-client-secret>
