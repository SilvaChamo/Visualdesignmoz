# VisualDesign — variáveis de produção (servidor Hetzner)
# Copiar para: /home/visualdesignmoz.com/public_html/.env.local

# ── Supabase self-hosted (Hetzner) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase.visualdesignmoz.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY do ficheiro .env do Supabase Docker>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY do ficheiro .env do Supabase Docker>

# Opcional: chave publishable (se usar o novo formato de keys)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<SUPABASE_PUBLISHABLE_KEY>

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_IP=37.27.17.25
NEXT_PUBLIC_WEBMAIL_URL=https://webmail.visualdesignmoz.com

# ── DirectAdmin (admin do servidor) ──────────────────────────
DIRECTADMIN_HOST=host.visualdesignmoz.com
DIRECTADMIN_PORT=2026
DIRECTADMIN_PROTOCOL=https
DIRECTADMIN_USER=admin
DIRECTADMIN_PASSWORD=<password>
# Alternativa: DIRECTADMIN_LOGIN_KEY=<login-key>

# Revendedores: 100% automático — credenciais em Supabase ao definir role=reseller
# (sync admin, PATCH papel, ou primeiro acesso a /revendedor). Só precisa DIRECTADMIN_* admin.
# Opcional: pacote por defeito | mapa email→username DA (contas já existentes, ex. Osher)
# DIRECTADMIN_RESELLER_DEFAULT_PACKAGE=reseller
# RESELLER_DA_USERNAME_MAP={"osher@oshercollective.com":"oshercollective","geral@oshercollective.com":"oshercollective"}
# CRON_SECRET=<secret>  # para GET /api/cron/reseller-provision

# Email: MX Brevo inbound (receção) + Exim smarthost (envio). Caixas no DirectAdmin.
# SERVER_SSH_PORT=2234
# SERVER_SSH_KEY_PATH=/root/.ssh/...  (ou SSH_PRIVATE_KEY na Vercel)
# BREVO_INBOUND_WEBHOOK_SECRET=<opcional>

# ── Email transaccional do site (Brevo relay — Vercel) ──
# NÃO usar host.visualdesignmoz.com na Vercel: Exim aceita mas porta 25 bloqueada.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ad3ca6001@smtp-brevo.com
SMTP_PASS=<chave-smtp-brevo-xsmtpsib-...>
SMTP_MASTER_PASSWORD=<mesma-chave-brevo-xsmtpsib>
BREVO_SMTP_USER=ad3ca6001@smtp-brevo.com
# Alternativa (recomendada): API REST — chave xkeysib no painel Brevo → SMTP e API
BREVO_API_KEY=<chave-api-brevo-xkeysib>
SITE_EMAIL_FROM=Visualdesign <noreply@visualdesignmoz.com>
PASSWORD_RESET_USE_SITE_SMTP=true
NEXT_PUBLIC_SITE_URL=https://visualdesignmoz.com

# ── Domínios (Porkbun) ───────────────────────────────────────
PORKBUN_API_KEY=<key>
PORKBUN_SECRET_KEY=<secret>
