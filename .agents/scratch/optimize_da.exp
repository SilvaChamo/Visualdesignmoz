#!/usr/bin/expect -f
set timeout 60
spawn ssh -o StrictHostKeyChecking=no root@109.199.104.22 "cat << 'EOF' > /root/da_optimize.sh
#!/bin/bash
echo 'Setting hostname...'
/usr/local/directadmin/scripts/hostname.sh painel.visualdesigne.com

echo 'Configuring CustomBuild...'
cd /usr/local/directadmin/custombuild
./build update
./build set webserver openlitespeed
./build set php1_release 8.3
./build set php2_release 8.2
./build set php3_release 8.1
./build set php4_release no
./build set php1_mode lsphp
./build set php2_mode lsphp
./build set php3_mode lsphp

echo 'Building OpenLiteSpeed and PHP in background...'
nohup bash -c './build openlitespeed && ./build php n && ./build rewrite_confs && /usr/local/directadmin/scripts/letsencrypt.sh request_single painel.visualdesigne.com 4096' > /root/da_build.log 2>&1 &
echo 'Optimization script started successfully.'
EOF
chmod +x /root/da_optimize.sh
/root/da_optimize.sh
"
expect {
    "*assword:*" {
        send "Meckito#77?*\r"
        exp_continue
    }
    eof
}
