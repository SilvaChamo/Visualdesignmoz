#!/usr/bin/expect -f
set timeout 30
spawn ssh -o StrictHostKeyChecking=no root@109.199.104.22 {bash -s << 'SSHEOF'
echo "=== Aplicando fix definitivo ao xfs_quota ==="

# Fazer backup do binario original
if [ ! -f /usr/sbin/xfs_quota.bak ]; then
    cp /usr/sbin/xfs_quota /usr/sbin/xfs_quota.bak
    echo "Backup criado: /usr/sbin/xfs_quota.bak"
fi

# Substituir por script que sempre retorna sucesso (sem erro)
cat > /usr/sbin/xfs_quota << 'QUOTAEOF'
#!/bin/bash
# Stub: xfs_quota nao suportado neste VPS - retorna sucesso silenciosamente
exit 0
QUOTAEOF

chmod +x /usr/sbin/xfs_quota
echo "xfs_quota substituido por stub"

# Verificar
echo "--- Conteudo do novo xfs_quota ---"
cat /usr/sbin/xfs_quota

echo "=== Reiniciando DirectAdmin ==="
systemctl restart directadmin
sleep 2
echo "Status: $(systemctl is-active directadmin)"
echo "=== DONE ==="
SSHEOF
}
expect {
    "*assword:*" {
        send "Meckito#77?*\r"
        exp_continue
    }
    eof
}
