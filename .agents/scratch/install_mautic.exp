#!/usr/bin/expect -f
set timeout 300
spawn ssh -o StrictHostKeyChecking=no root@109.199.104.22 {bash -s << 'SSHEOF'
echo "=== A instalar Mautic via Composer (método oficial) ==="
cd /var/www

# Remover pasta vazia se existir
rm -rf /var/www/mautic

# Instalar Mautic 5 via Composer (método oficial)
/usr/local/bin/composer create-project mautic/recommended-project:^5.0 mautic \
    --no-interaction \
    --prefer-dist \
    2>&1 | tail -20

echo ""
echo "=== Resultado ==="
if [ -f /var/www/mautic/index.php ]; then
    echo "SUCCESS: Mautic instalado!"
    ls /var/www/mautic/
else
    echo "FAILED: index.php não encontrado"
    ls /var/www/mautic/ 2>/dev/null || echo "Pasta vazia"
fi
SSHEOF
}
expect {
    "*assword:*" {
        send "Meckito#77?*\r"
        exp_continue
    }
    eof
}
