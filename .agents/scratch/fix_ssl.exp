#!/usr/bin/expect -f
set timeout 60
spawn ssh -o StrictHostKeyChecking=no root@109.199.104.22 {bash -s << 'SSHEOF'
echo "=== Emitindo SSL server_cert para painel.visualdesignmoz.com ==="
/usr/local/directadmin/scripts/letsencrypt.sh server_cert painel.visualdesignmoz.com
echo "Exit: $?"

echo ""
echo "=== Verificar certificado activo no DA ==="
openssl s_client -connect 109.199.104.22:2222 -servername painel.visualdesignmoz.com 2>/dev/null | openssl x509 -noout -subject -dates 2>/dev/null || echo "Não foi possível verificar"
SSHEOF
}
expect {
    "*assword:*" {
        send "Meckito#77?*\r"
        exp_continue
    }
    eof
}
