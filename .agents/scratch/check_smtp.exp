#!/usr/bin/expect -f
set timeout 30
spawn ssh -o StrictHostKeyChecking=no root@109.199.104.22 "
# Criar dominio para email de sistema se nao existir
# Verificar se exim está a correr
systemctl is-active exim | head -1
# Ver a configuracao SMTP
cat /etc/exim.conf | grep -E 'port|daemon_smtp' | head -5
# Ver portas abertas
ss -tlnp | grep -E ':25|:587|:465'
"
expect {
    "*assword:*" {
        send "Meckito#77?*\r"
        exp_continue
    }
    eof
}
